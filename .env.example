# @BotFather → /newbot → token (no spaces or quotes in Vercel)
TELEGRAM_BOT_TOKEN=my_token

# Your numeric chat id only (see below). In Vercel do not wrap in quotes.
TELEGRAM_CHAT_ID=my_chat_id

# Neon via Vercel Storage: Vercel injects DATABASE_URL (or POSTGRES_URL).
# Run neon/schema.sql once in the Neon SQL Editor.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Webhook secret (same value in setWebhook secret_token). Optional: omit in Vercel + setWebhook without secret_token.
TELEGRAM_WEBHOOK_SECRET=long-random-string

# Full site URL for webhook setup helper (origin only is OK; /api/telegram is appended)
# TELEGRAM_WEBHOOK_URL=https://your-project.vercel.app

# Random string; used only for GET /api/telegram/set-webhook?key=... (register webhook + align secret)
# TELEGRAM_WEBHOOK_SETUP_KEY=another-long-random-string

# How to get chat id:
# 1) Open your bot in Telegram, send /start
# 2) Open https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# 3) Find "chat":{"id": 123456789 — that number is TELEGRAM_CHAT_ID
# Groups: id is often negative (e.g. -100...). Bot must be in the group.
