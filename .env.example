# @BotFather → /newbot → token (no spaces or quotes in Vercel)
TELEGRAM_BOT_TOKEN=my_token

# Your numeric chat id only (see below). In Vercel do not wrap in quotes.
TELEGRAM_CHAT_ID=my_chat_id

# How to get chat id:
# 1) Open your bot in Telegram, send /start
# 2) Open https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# 3) Find "chat":{"id": 123456789 — that number is TELEGRAM_CHAT_ID
# Groups: id is often negative (e.g. -100...). Bot must be in the group.

# Cal.com embed — public link path only (no https://), e.g. username/home-visit
# Create an event type at https://cal.com → Event types → copy slug from booking URL.
NEXT_PUBLIC_CALCOM_LINK=your-username/your-event-slug

# Optional: only if you self-host Cal.com
# NEXT_PUBLIC_CALCOM_ORIGIN=https://app.cal.com
