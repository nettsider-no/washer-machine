# @BotFather → /newbot → token (no spaces or quotes in Vercel)
TELEGRAM_BOT_TOKEN=my_token

# Your numeric chat id only (see below). In Vercel do not wrap in quotes.
TELEGRAM_CHAT_ID=my_chat_id

# How to get chat id:
# 1) Open your bot in Telegram, send /start
# 2) Open https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# 3) Find "chat":{"id": 123456789 — that number is TELEGRAM_CHAT_ID
# Groups: id is often negative (e.g. -100...). Bot must be in the group.

# Cal.com embed — path after cal.com (or full URL — both work), e.g.:
# NEXT_PUBLIC_CALCOM_LINK=your-username/home-visit
# NEXT_PUBLIC_CALCOM_LINK=https://cal.com/your-username/home-visit
# Open the booking page in a browser; if it loads, the path is correct. Event must be public.
NEXT_PUBLIC_CALCOM_LINK=your-username/your-event-slug

# Optional: only if you self-host Cal.com
# NEXT_PUBLIC_CALCOM_ORIGIN=https://app.cal.com

# Cal.com → Telegram (webhook). Generate a long random string; paste the SAME value in:
# Cal.com → Settings → Developer → Webhooks → your endpoint → Secret
CAL_WEBHOOK_SECRET=replace_with_long_random_string

# Webhook URL to paste in Cal.com (replace domain):
# https://YOUR_DOMAIN/api/webhooks/cal
